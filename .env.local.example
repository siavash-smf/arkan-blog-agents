# ───────────────────────────────────────────────
# آرکان — سیستم بلاگ مولتی‌ایجنت (فاز ۳)
# این فایل را به .env.local کپی کنید و مقادیر را پر کنید.
# ───────────────────────────────────────────────

# ── مدل زبانی (اجباری) ──────────────────────────────────────
# همه‌ی ایجنت‌ها از طریق OpenRouter کار می‌کنند (یک کلید برای همه‌ی مدل‌ها).
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# مدل پیش‌فرض همه‌ی ایجنت‌ها (slug از openrouter.ai/models)
PIPELINE_MODEL=google/gemini-2.5-flash
# اختیاری: مدل قوی‌تر فقط برای ایجنت «نویسنده» (اگر خالی باشد از PIPELINE_MODEL استفاده می‌شود)
# WRITER_MODEL=anthropic/claude-sonnet-4.5

# ── جستجوی وب برای ایجنت پژوهشگر (اختیاری) ─────────────────
# اگر کلید Tavily بدهید، پژوهشگر واقعاً وب را جستجو می‌کند؛
# در غیر این صورت به دانش خود مدل تکیه می‌کند (پایپ‌لاین همچنان کار می‌کند).
# کلید رایگان: https://tavily.com
# TAVILY_API_KEY=tvly-xxxxxxxxxxxx

# ── ذخیره‌سازی (اختیاری برای اجرای محلی) ────────────────────
# بدون Supabase سیستم در «حالت حافظه» اجرا می‌شود (داده‌ها با ری‌استارت پاک می‌شوند).
# برای دیپلوی روی Vercel، تنظیم Supabase اجباری است.
# اسکیمای جدول‌ها: supabase/schema.sql
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── امنیت استودیو (برای دیپلوی عمومی توصیه می‌شود) ──────────
# اگر تنظیم شود، صفحه‌ی /studio و APIهای مدیریتی رمز می‌خواهند.
# STUDIO_PASSWORD=یک-رمز-قوی

# ── اجرای خودکار هفتگی (کرون Vercel) ────────────────────────
# با این دستور بسازید: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# CRON_SECRET=یک-رشته-تصادفی
